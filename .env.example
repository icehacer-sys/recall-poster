# Copy to .env and fill in. .env is gitignored — never commit real tokens.

# --- Secrets ---
# Claude (captions + topic generation). console.anthropic.com
ANTHROPIC_API_KEY=
# OpenAI (gpt-image-2 slide art). platform.openai.com
OPENAI_API_KEY=
# Long-lived Instagram Graph token for @recallengine (~60 days; plan a refresh).
IG_ACCESS_TOKEN=

# --- Image hosting (public GitHub raw URLs) ---
# Base raw URL for THIS repo. Meta fetches each slide from:
#   <GITHUB_RAW_BASE>/posts/<slug>/slideN.jpg
# Form: https://raw.githubusercontent.com/<user>/<repo>/<branch>
GITHUB_RAW_BASE=https://raw.githubusercontent.com/<your-user>/recall-poster/main

# --- Tuning (safe defaults) ---
# BOT_HANDLE=@recallengine
# CTA destination shown as "link in bio" (placeholder until confirmed). Not printed on slides.
# BOT_APP_URL=
# BOT_MODEL=claude-haiku-4-5-20251001
# BOT_IMAGE_MODEL=gpt-image-2
# BOT_IMAGE_SIZE=1024x1024
# BOT_IMAGE_QUALITY=medium        # low | medium | high | auto  (medium ~3-4c/image)
# BOT_SLIDE_SIZE=1080             # final square px after processing
# BOT_QUEUE_TARGET=7
# BOT_AUTO_APPROVE=off            # off = generated topics wait for review before posting
# BOT_RENDER_LOOKAHEAD_H=26       # pre-render+commit slides this far ahead of postAt

# Required to actually post in live mode. Must equal "yes".
BOT_CONFIRM_LIVE=
