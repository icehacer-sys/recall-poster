{
  "name": "recall-poster",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Daily Instagram carousel auto-poster for @recallengine. Generates gpt-image-2 slides + Claude captions for high-yield medical exam content and publishes via the Instagram Graph API.",
  "engines": {
    "node": ">=18.17"
  },
  "scripts": {
    "dry": "tsx src/index.ts --dry-run",
    "sample": "tsx src/index.ts --sample",
    "render": "tsx src/index.ts --render",
    "live": "tsx src/index.ts --live",
    "generate": "tsx src/generate.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "dotenv": "^16.4.5",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
